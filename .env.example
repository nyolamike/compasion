# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email Service Configuration
# Set to 'true' for demo mode (no actual emails sent, just console logs)
# Set to 'false' for production mode (real emails via Supabase Edge Functions)
VITE_EMAIL_DEMO_MODE=true

# Email Sender Configuration (used in production mode)
VITE_FROM_EMAIL=noreply@trainingportal.com
VITE_FROM_NAME=Training Portal
